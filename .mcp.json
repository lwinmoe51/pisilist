{
  "mcpServers": {
    "firebase": {
      "type": "plugin",
      "plugin": "firebase@claude-plugins-official",
      "description": "Firebase MCP server for Firestore, Auth, Cloud Functions, and Security Rules operations"
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "description": "Context7 MCP server for up-to-date library/API documentation lookups (React Native, Expo, Firebase SDK)"
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ],
      "env": {
        "CHROME_PATH": "/mnt/c/Program Files/Google/Chrome/Application/chrome.exe"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github@latest"
      ]
    }
  }
}
